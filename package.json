{
  "name": "vscode-gsn-preview",
  "displayName": "vscode-gsn-preview",
  "description": "Preview gsn2x files in VSCode",
  "version": "0.0.1",
  "publisher": "org.jonaswolf",
  "engines": {
    "vscode": "^1.87.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gsn2xPreview.open",
        "title": "Preview file using gsn2x"
      }
    ],
    "configuration": {
      "title": "gsn2x Configuration",
      "properties": {
        "gsn2xPreview.gsn2xPath": {
          "type": "string",
          "default": "gsn2x",
          "description": "Path to gsn2x"
        },
        "gsn2xPreview.wordWrap": {
          "type": "integer",
          "default": "15",
          "description": "Optional word wrap"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.87.0",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vscode/test-cli": "^0.0.6",
    "@vscode/test-electron": "^2.3.9",
    "eslint": "^8.56.0",
    "typescript": "^5.4.3"
  }
}
