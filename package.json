{
  "name": "gsn-preview",
  "displayName": "gsn2x Preview",
  "description": "Live preview of GSN YAML files with interactive navigation, zoom controls, and support for statistics, evidence, and additional diagram views",
  "repository": {
    "url": "https://github.com/jonasthewolf/vscode-gsn2x-preview"
  },
  "version": "0.2.2",
  "license": "MIT",
  "publisher": "jonaswolf-org",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gsn2xPreview.open",
        "title": "Preview GSN File"
      }
    ],
    "configuration": {
      "title": "GSN Preview",
      "properties": {
        "gsn2xPreview.gsn2xPath": {
          "type": "string",
          "default": "gsn2x",
          "description": "Path to the gsn2x executable. If not found in PATH, specify the full path."
        },
        "gsn2xPreview.wordWrap": {
          "type": "integer",
          "default": 15,
          "description": "Maximum width for text wrapping in diagrams (characters)"
        },
        "gsn2xPreview.useNightlyBuilds": {
          "type": "boolean",
          "default": false,
          "description": "Use the latest nightly (pre-release) build of gsn2x instead of the latest stable release when downloading or checking for updates."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.{ts,js}\" \"package.json\" \"README.md\" \"tsconfig.json\" \".eslintrc.json\" \".prettierrc\" \".github/workflows/ci.yml\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\" \"package.json\" \"README.md\" \"tsconfig.json\" \".eslintrc.json\" \".prettierrc\" \".github/workflows/ci.yml\"",
    "audit": "npm audit --production --audit-level=moderate",
    "check-license": "license-checker --production --onlyAllow \"MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;Python-2.0\""
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5",
    "@types/node": "18.x",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.0.0",
    "license-checker": "^25.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.3"
  }
}
